# === Zerodha Kite Connect credentials ===
# Get these from https://developers.kite.trade (requires paid API subscription, ~Rs.2000/month)
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
# Access token is generated daily via the login flow (see README) - leave blank initially
KITE_ACCESS_TOKEN=

# === Trading mode ===
# paper = simulated orders, no real money. live = real orders via Zerodha.
TRADING_MODE=paper

# === Database ===
DATABASE_URL=sqlite:///./quant_platform.db

# === Risk management ===
MAX_POSITION_PCT=0.10
MAX_PORTFOLIO_EXPOSURE_PCT=0.60
DEFAULT_STOP_LOSS_PCT=0.02
DEFAULT_TAKE_PROFIT_PCT=0.05
STARTING_CAPITAL=100000

# === Dashboard ===
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# === Logging ===
LOG_LEVEL=INFO
